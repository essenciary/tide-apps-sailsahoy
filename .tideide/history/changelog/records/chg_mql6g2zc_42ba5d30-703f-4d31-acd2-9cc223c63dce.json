    "content": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Sailing Weather — Wind, Waves & Direction</title>\n  <meta name=\"description\" content=\"Interactive sailing weather app with wind animations, compass rose direction analysis, and marine forecast\">\n\n  <!-- Leaflet CSS -->\n  <link rel=\"stylesheet\" href=\"https://unpkg.com/leaflet@1.9.4/dist/leaflet.css\"\n    integrity=\"sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=\" crossorigin=\"\">\n\n  <!-- Inter + JetBrains Mono fonts -->\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap\" rel=\"stylesheet\">\n\n  <!-- App CSS -->\n  <link rel=\"stylesheet\" href=\"/_assets/sailing-weather.css\">\n</head>\n<body>\n\n  <!-- Loading overlay — shown until first data fetch completes -->\n  <div id=\"loading-overlay\">\n    <div class=\"spinner\"></div>\n    <div class=\"loading-text\">Fetching weather data…</div>\n  </div>\n\n  <!-- Map fills the entire viewport -->\n  <div id=\"map\"></div>\n\n  <!-- Canvas overlay for wind/wave/rain/snow particle animations -->\n  <canvas id=\"weather-canvas\"></canvas>\n\n  <!-- Current Conditions Panel (top-left) -->\n  <div id=\"conditions-panel\" class=\"panel\">\n    <div class=\"conditions-header\">\n      <h2>Current Conditions</h2>\n      <span class=\"update-time\">Loading…</span>\n    </div>\n    <div class=\"condition-row\">\n      <span class=\"condition-label\">Waiting for data</span>\n      <span class=\"condition-value\">—</span>\n    </div>\n  </div>\n\n  <!-- Compass Rose Panel (top-right) -->\n  <div id=\"compass-panel\" class=\"panel\">\n    <div class=\"compass-title\">Direction Analysis</div>\n    <div class=\"compass-rose\">\n      <div class=\"compass-center\">⚓</div>\n    </div>\n  </div>\n\n  <!-- Boat Info Bar (bottom-left) -->\n  <div id=\"info-bar\">\n    <div class=\"info-item\">\n      <span class=\"info-label\">LAT</span>\n      <span class=\"info-value\" id=\"info-lat\">—</span>\n    </div>\n    <div class=\"info-item\">\n      <span class=\"info-label\">LON</span>\n      <span class=\"info-value\" id=\"info-lon\">—</span>\n    </div>\n  </div>\n\n  <!-- Layer Toggle Panel (bottom-right, above action buttons) -->\n  <div id=\"layer-panel\" class=\"panel\">\n    <div class=\"layer-panel-title\">Layers</div>\n    <div class=\"layer-row\">\n      <input type=\"checkbox\" id=\"layer-wind\" class=\"layer-toggle\" data-layer=\"wind\" checked>\n      <label for=\"layer-wind\">Wind</label>\n    </div>\n    <div class=\"layer-row\">\n      <input type=\"checkbox\" id=\"layer-waves\" class=\"layer-toggle\" data-layer=\"waves\" checked>\n      <label for=\"layer-waves\">Waves</label>\n    </div>\n    <div class=\"layer-row\">\n      <input type=\"checkbox\" id=\"layer-precip\" class=\"layer-toggle\" data-layer=\"precip\" checked>\n      <label for=\"layer-precip\">Precipitation</label>\n    </div>\n    <div class=\"layer-row\">\n      <input type=\"checkbox\" id=\"layer-clouds\" class=\"layer-toggle\" data-layer=\"clouds\" checked>\n      <label for=\"layer-clouds\">Clouds</label>\n    </div>\n  </div>\n\n  <!-- Action Buttons (bottom-right) -->\n  <div id=\"action-buttons\">\n    <button id=\"location-btn\" type=\"button\" aria-label=\"Get my location\"\n      title=\"Use your device GPS to center the map on your current position\">\n      <span class=\"location-icon\">📍</span>\n      My Location\n    </button>\n    <button id=\"refresh-btn\" type=\"button\" aria-label=\"Refresh weather data\">\n      <span class=\"refresh-icon\">⟳</span>\n      Refresh\n    </button>\n  </div>\n\n  <!-- Timeline Panel (bottom-center) -->\n  <div id=\"timeline-panel\" class=\"panel\">\n    <div class=\"timeline-header\">\n      <span class=\"timeline-label\">Forecast Timeline</span>\n      <span class=\"timeline-time\" id=\"timeline-time\">—</span>\n    </div>\n    <input type=\"range\" class=\"timeline-slider\" id=\"timeline-slider\"\n      min=\"0\" max=\"47\" value=\"0\" aria-label=\"Forecast hour selector\">\n    <div class=\"timeline-ticks\" id=\"timeline-ticks\"></div>\n  </div>\n\n  <!-- Toast notification container — used for location errors and other alerts -->\n  <div id=\"toast-container\"></div>\n\n  <!-- Leaflet JS -->\n  <script src=\"https://unpkg.com/leaflet@1.9.4/dist/leaflet.js\"\n    integrity=\"sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=\" crossorigin=\"\"></script>\n\n  <!-- App JS -->\n  <script src=\"/_assets/sailing-weather.js\"></script>\n</body>\n</html>",
