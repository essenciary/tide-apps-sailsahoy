  {
    "method": "POST",
    "path": "/api/route-plan",
    "handlerName": "getRoutePlan",
    "registeredAt": "2026-06-26T16:54:49.187Z",
    "schema": {
      "body": {
        "properties": {
          "points": {
            "description": "Ordered points; index 0 is the origin (boat), the rest are waypoints",
            "items": {
              "properties": {
                "lat": {
                  "description": "Latitude (-90..90)",
                  "type": "number"
                },
                "lon": {
                  "description": "Longitude (-180..180)",
                  "type": "number"
                }
              },
              "required": [
                "lat",
                "lon"
              ],
              "type": "object"
            },
            "type": "array"
          },
          "speed": {
            "description": "Boat speed in knots (defaults to ROUTE_DEFAULT_SPEED_KNOTS)",
            "type": "number"
          },
          "startTime": {
            "description": "Departure time in UTC milliseconds (defaults to now)",
            "type": "number"
          }
        },
        "required": [
          "points"
        ],
        "type": "object"
      },
      "description": "Given an ordered list of points (origin first, then waypoints), returns per-leg distance, bearing, duration and ETA at the given boat speed, plus per-leg weather risk warnings.",
      "responses": {
        "200": {
          "description": "Weather-aware route plan with legs and totals",
          "schema": {
            "properties": {
              "legs": {
                "type": "array"
              },
              "speed": {
                "type": "number"
              },
              "startTime": {
                "type": "number"
              },
              "totals": {
                "properties": {
                  "departTimeMs": {
                    "type": "number"
                  },
                  "distanceNm": {
                    "type": "number"
                  },
                  "durationHours": {
                    "type": "number"
                  },
                  "etaMs": {
                    "type": "number"
                  }
                },
                "type": "object"
              }
            },
            "type": "object"
          }
        },
        "400": {
          "description": "Validation error (bad points or speed)"
        },
        "502": {
          "description": "Weather data could not be fetched for the route"
        }
      },
      "summary": "Compute a weather-aware route plan",
      "tags": [
        "route"
      ]
    },
    "module": "route"
  },
